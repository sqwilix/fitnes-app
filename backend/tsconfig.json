{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],

    "strict": true,
    "noImplicitAny": true,                              
    "strictNullChecks": true,                           

    "esModuleInterop": true,                       
    "skipLibCheck": true,                          
    "forceConsistentCasingInFileNames": true,      
    
    /* Дополнительно */
    "resolveJsonModule": true,                          
    "sourceMap": true,                                  
    "removeComments": true                              
  },
  "include": ["src/**/*"],                               
  "exclude": ["node_modules", "prisma", "**/*.spec.ts"]            
}