// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TRAINER
  CLIENT
}

enum SubscriptionStatus {
  ACTIVE
  FROZEN
  EXPIRED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshToken   RefreshToken[]
  trainerProfile TrainerProfile?
  clientProfile  ClientProfile?
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiredAt DateTime
  createdAt DateTime @default(now())
}

model TrainerProfile {
  id             String  @id @default(uuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty      String?
  specialization String?
  experience     Int?
  bio            String?

  clients  ClientProfile[]
  sessions WorkoutSession[]
}

model ClientProfile {
  id        String          @id @default(uuid())
  userId    String          @unique
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainerId String?
  trainer   TrainerProfile? @relation(fields: [trainerId], references: [id], onDelete: SetNull)
  weight    Int?
  height    Int?
  goal      String?

  subscriptions Subscription[]
  sessions      WorkoutSession[]
  workoutLogs   WorkoutLogs[]
  aiGenerations aiGeneration[]
}

model Subscription {
  id                  String             @id @default(uuid())
  clientId            String
  client              ClientProfile      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title               String
  status              SubscriptionStatus @default(ACTIVE)
  totalLessons        Int
  remainingLesson     Int
  startDate           DateTime           @default(now())
  endDate             DateTime
  freezeDaysAllowed   Int                @default(30)
  freezeDaysRemaining Int                @default(30)
  frozenAt            DateTime?
}

model WorkoutSession {
  id          String          @id @default(uuid())
  trainerId   String?
  title       String?
  trainer     TrainerProfile? @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  clientId    String
  client      ClientProfile   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date        DateTime
  isCompleted Boolean         @default(false)

  exercises Exercise[]
}

model WorkoutLogs {
  id       String        @id @default(uuid())
  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date     DateTime      @default(now())
  exercise String
  sets     Json
}

model aiGeneration {
  id        String        @id @default(uuid())
  clientId  String
  client    ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  prompt    String
  response  Json
  createdAt DateTime      @default(now())
}

model Exercise {
  id               String         @id @default(uuid())
  order            Int
  name             String
  reps             String
  sets             String
  weight           String
  workoutSessionId String
  workoutSession   WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  isCompleted      Boolean        @default(false)
}
